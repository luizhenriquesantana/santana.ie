---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const resume = await getEntry('resume', 'resume');

if (!resume) {
  throw new Error('Missing resume content entry.');
}

const { Content } = await render(resume);
---

<BaseLayout title={`${resume.data.title} | Resume PDF`} bodyClass="print-body">
  <article class="print-resume">
    <header>
      <h1>{resume.data.title}</h1>
      <p>{resume.data.role} · {resume.data.location}</p>
      <p>
        <a href={`mailto:${resume.data.email}`}>{resume.data.email}</a> ·
        <a href={resume.data.github}>GitHub</a> ·
        <a href={resume.data.linkedin}>LinkedIn</a>
      </p>
    </header>
    <section class="print-highlights">
      {resume.data.highlights.map((highlight) => <p>{highlight}</p>)}
    </section>
    <section class="print-skills">
      <h2>Skills</h2>
      <p>{resume.data.skills.join(' · ')}</p>
    </section>
    <Content />
  </article>
</BaseLayout>
